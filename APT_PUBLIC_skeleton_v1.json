import json
from copy import deepcopy

KEEP_PUBCHEM = {
    "AtomicMass",
    "ElectronConfiguration",
    "ElectronAffinity",
    "StandardState",
    "MeltingPoint",
    "BoilingPoint",
    "OxidationStates",
    "Electronegativity",
    "Density",
    "AtomicRadius",
    "IonizationEnergy",
}

KEEP_BEST = {
    "sphere_size_ppm",
    "crust_whole_ppm",
    "crust_ucc_ppm",
    "urban_soils_ppm",
    # If you want seawater public, uncomment:
    # "seawater_w1_mgL",
    # "seawater_w2_mgL",
}

KEEP_LAYOUT = {"period", "group", "series", "display_row", "display_col", "block"}
KEEP_CATEGORY = {"major", "minor"}

def clean_pubchem(pub):
    if not isinstance(pub, dict):
        return None
    out = {}
    for k in KEEP_PUBCHEM:
        v = pub.get(k, "")
        # keep non-empty only
        if v is None:
            continue
        s = str(v).strip()
        if s == "":
            continue
        out[k] = v
    return out or None

def clean_element(e):
    out = {
        "Z": e.get("Z"),
        "symbol": e.get("symbol"),
        "name": e.get("name"),
        "layout": {k: e.get("layout", {}).get(k) for k in KEEP_LAYOUT},
        "category": {k: e.get("category", {}).get(k) for k in KEEP_CATEGORY},
        "best": {k: e.get("best", {}).get(k) for k in KEEP_BEST},
    }

    # prune None layout/category keys to keep it tidy
    out["layout"] = {k: v for k, v in out["layout"].items() if v is not None}
    out["category"] = {k: v for k, v in out["category"].items() if v is not None}
    out["best"] = {k: v for k, v in out["best"].items() if v is not None}

    pub = clean_pubchem(e.get("pubchem"))
    if pub:
        out["pubchem"] = pub

    return out

def main(inp_path, out_path):
    with open(inp_path, "r", encoding="utf-8") as f:
        payload = json.load(f)

    items = payload["data"] if isinstance(payload, dict) and "data" in payload else payload
    cleaned = [clean_element(e) for e in items]

    with open(out_path, "w", encoding="utf-8") as f:
        json.dump(cleaned, f, ensure_ascii=False, indent=2)

if __name__ == "__main__":
    main("APT_SUBMARINE_v2.json", "APT_PUBLIC_skeleton_v1.json")
